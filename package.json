{
  "name": "canvas-cli",
  "version": "2.1.8",
  "description": "Canvas CLI",
  "author": "me@idnc.sk",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "bin": {
    "canvas": "bin/canvas.js",
    "context": "bin/context.js",
    "ctx": "bin/ctx.js",
    "dot": "bin/dot.js",
    "ws": "bin/ws.js",
    "agent": "bin/agent.js",
    "hi": "bin/hi.js"
  },
  "scripts": {
    "lint": "eslint \"**/*.js\"",
    "lint:fix": "eslint \"**/*.js\" --fix",
    "format": "prettier --write \"**/*.{js,md}\"",
    "format:js": "prettier --write \"**/*.js\"",
    "format:md": "prettier --write \"**/*.md\"",
    "build": "npm run build:all",
    "build:all": "npm run build:linux && npm run build:macos",
    "build:linux": "bun build --compile --target=bun-linux-x64 --minify --icon=assets/icons/canvas.png --outfile=dist/canvas-linux ./bin/canvas.js",
    "build:linux-arm": "bun build --compile --target=bun-linux-arm64 --minify --icon=assets/icons/canvas.png --outfile=dist/canvas-linux-arm ./bin/canvas.js",
    "build:macos": "bun build --compile --target=bun-darwin-x64 --minify --icon=assets/icons/canvas.png --outfile=dist/canvas-macos ./bin/canvas.js",
    "build:macos-arm": "bun build --compile --target=bun-darwin-arm64 --minify --icon=assets/icons/canvas.png --outfile=dist/canvas-macos-arm ./bin/canvas.js",
    "build:windows": "bun build --compile --target=bun-windows-x64 --minify --icon=assets/icons/canvas.ico --outfile=dist/canvas-windows.exe ./bin/canvas.js",
    "build:dev": "bun build --compile --outfile=dist/canvas-dev ./bin/canvas.js",
    "generate:icons": "scripts/generate-icons.sh",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/canvas-ui/canvas-cli.git"
  },
  "keywords": [
    "cli",
    "canvas",
    "context",
    "llm",
    "ollama",
    "shell"
  ],
  "dependencies": {
    "axios": "^1.13.6",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "conf": "^14.0.0",
    "date-fns": "^4.1.0",
    "debug": "^4.4.3",
    "minimist": "^1.2.8",
    "node-fetch": "^3.3.2",
    "node-machine-id": "^1.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "bun": "^1.3.11",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "pkg": {
    "outputPath": "bin",
    "targets": [
      "linux",
      "macos"
    ],
    "engines": {
      "node": ">=20.0.0"
    },
    "assets": [
      "./node_modules/axios/dist/node/axios.cjs"
    ]
  }
}
